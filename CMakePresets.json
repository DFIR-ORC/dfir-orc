{
    "version": 4,
    "configurePresets": [
        {
            "name": "dfir-orc-base",
            "hidden": true,
            "toolset": "v143",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/external/vcpkg_overlay_ports/current",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/external/vcpkg_overlay_triplets",
                "ORC_BUILD_APACHE_ORC": "OFF",
                "ORC_BUILD_FASTFIND": "ON",
                "ORC_BUILD_ORC": "ON",
                "ORC_BUILD_PARQUET": "OFF",
                "ORC_BUILD_SSDEEP": "OFF",
                "ORC_BUILD_JSON": "ON",
                "ORC_BUILD_BOOST_STACKTRACE": "OFF",
                "ORC_BUILD_TEST": "OFF",
                "ORC_BUILD_COMMAND": "ON",
                "ORC_DOWNLOADS_ONLY": "OFF",
                "ORC_DISABLE_PRECOMPILED_HEADERS": "OFF",
                "ORC_COMMAND_DD": "OFF",
                "ORC_COMMAND_FASTFIND": "ON",
                "ORC_COMMAND_FATINFO": "ON",
                "ORC_COMMAND_GETSAMPLES": "ON",
                "ORC_COMMAND_GETSECTORS": "ON",
                "ORC_COMMAND_GETTHIS": "ON",
                "ORC_COMMAND_NTFSINFO": "ON",
                "ORC_COMMAND_NTFSUTIL": "ON",
                "ORC_COMMAND_OBJINFO": "ON",
                "ORC_COMMAND_REGINFO": "ON",
                "ORC_COMMAND_TOOLEMBED": "ON",
                "ORC_COMMAND_USNINFO": "ON",
                "ORC_COMMAND_WOLFLAUNCHER": "ON"
            },
            "environment": {
                "VCPKG_FEATURE_FLAGS": "manifests,versions"
            }
        },
        {
            "name": "dfir-orc-x64",
            "inherits": "dfir-orc-base",
            "binaryDir": "${sourceDir}/build/dfir-orc-x64",
            "architecture": "x64",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static"
            }
        },
        {
            "name": "dfir-orc-x86",
            "inherits": "dfir-orc-base",
            "binaryDir": "${sourceDir}/build/dfir-orc-x86",
            "architecture": "Win32",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static"
            }
        },
        {
            "name": "dfir-orc-x86-xp",
            "inherits": "dfir-orc-base",
            "binaryDir": "${sourceDir}/build/dfir-orc-x86-xp",
            "architecture": "Win32",
            "toolset": "v141_xp",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static-xp",
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/external/vcpkg_overlay_ports/xp",
                "CMAKE_CXX_FLAGS": "/DGSL_USE_STD_BYTE=0"
            }
        },
        {
            "name": "dfir-orc-x64-xp",
            "inherits": "dfir-orc-base",
            "binaryDir": "${sourceDir}/build/dfir-orc-x64-xp",
            "architecture": "x64",
            "toolset": "v141_xp",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static-xp",
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/external/vcpkg_overlay_ports/xp",
                "CMAKE_CXX_FLAGS": "/DGSL_USE_STD_BYTE=0"
            }
        },
        {
            "name": "dfir-orc-arm64",
            "inherits": "dfir-orc-base",
            "binaryDir": "${sourceDir}/build/dfir-orc-arm64",
            "architecture": "arm64",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm64-windows-static"
            }
        },
        {
            "name": "capsule-base",
            "hidden": true,
            "toolset": "v141_xp",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/external/vcpkg_overlay_ports/xp",
                "VCPKG_OVERLAY_TRIPLETS": "${sourceDir}/external/vcpkg_overlay_triplets",
                "VCPKG_MANIFEST_DIR": "${sourceDir}/src/OrcCapsule",
                "ORC_BUILD_CAPSULE_ONLY": "ON"
            },
            "environment": {
                "VCPKG_FEATURE_FLAGS": "manifests,versions"
            }
        },
        {
            "name": "capsule-x86-xp",
            "inherits": "capsule-base",
            "binaryDir": "${sourceDir}/build/capsule-x86-xp",
            "architecture": "Win32",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static-xp"
            }
        },
        {
            "name": "capsule-x64-xp",
            "inherits": "capsule-base",
            "binaryDir": "${sourceDir}/build/capsule-x64-xp",
            "architecture": "x64",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static-xp"
            }
        },
        {
            "name": "capsule-arm64",
            "inherits": "capsule-base",
            "toolset": "v143",
            "binaryDir": "${sourceDir}/build/capsule-arm64",
            "architecture": "ARM64",
            "cacheVariables": {
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/external/vcpkg_overlay_ports/current",
                "VCPKG_TARGET_TRIPLET": "arm64-windows-static"
            }
        }
    ],
