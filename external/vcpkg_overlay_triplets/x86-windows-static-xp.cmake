set(VCPKG_C_FLAGS "/D_WIN32_WINNT=0x0501 /DWINVER=0x0501 /DNTDDI_VERSION=0x05010200")
set(VCPKG_CXX_FLAGS "/std:c++${CMAKE_CXX_STANDARD} /D_SILENCE_ALL_CXX17_DEPRECATION_WARNINGS /D_WIN32_WINNT=0x0501 /DWINVER=0x0501 /DNTDDI_VERSION=0x05010200")
